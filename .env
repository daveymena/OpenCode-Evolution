# ============================================
# OpenCode Evolution - Configuracion Completa
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# Base de datos PostgreSQL (persistencia)
# ============================================
DATABASE_URL=postgres://postgres:6715320@tecnology_base-open:5432/davey?sslmode=disable
DB_HOST=tecnology_base-open
DB_PORT=5432
DB_NAME=davey
DB_USER=postgres
DB_PASSWORD=6715320

# ============================================
# Autenticacion del servidor OpenCode
# ============================================
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_SERVER_PASSWORD=opencode_evolution_2026

# ============================================
# Configuracion OpenCode SaaS (multi-tenant)
# ============================================
# OPENCODE_APPNAME aísla datos por usuario.
# Se sobreescribe por cada instancia.
# Los usuarios se definen en scripts/users.conf
OPENCODE_APP_NAME=opencode

# ============================================
# URLs del sistema
# ============================================
EASYPANEL_URL=https://tecnology-opencode-ia.vr7gwz.easypanel.host/
INSTALLER_URL=https://github.com/daveymena/OpenCode-Evolution/releases/download/v1.0.0/OpenCode-Evolution-Setup.exe

