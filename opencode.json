{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "kilo-free": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kilo Gateway (Free)",
      "options": {
        "baseURL": "https://api.kilo.ai/api/gateway",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Code/1.90.0 Chrome/120.0.6099.291 Electron/28.2.8 Safari/537.36",
          "Referer": "vscode-webview://kilo-extension",
          "Origin": "vscode-webview://kilo-extension",
          "Sec-Fetch-Dest": "empty",
          "Sec-Fetch-Mode": "cors",
          "Sec-Fetch-Site": "cross-site",
          "x-kilo-client": "vscode"
        }
      },
      "models": {
        "deepseek/deepseek-v4-flash:free": {
          "name": "DeepSeek V4 Flash (Free)"
        },
        "openai/gpt-oss-120b:free": {
          "name": "GPT OSS 120B (Free)"
        },
        "openai/gpt-oss-20b:free": {
          "name": "GPT OSS 20B (Free)"
        },
        "google/gemma-4-31b-it:free": {
          "name": "Gemma 4 31B (Free)"
        },
        "nvidia/nemotron-nano-12b-2-vl:free": {
          "name": "Nemotron Nano 12B (Free)"
        },
        "poolside/laguna-m-1:free": {
          "name": "Poolside Laguna M1 (Free)"
        }
      }
    }
  },
  "model": "kilo-free/deepseek/deepseek-v4-flash:free",
  "permission": {
    "edit": "allow",
    "bash": "allow"
  }
}
